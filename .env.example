# ================================
# NEXUSBOT — Configuration
# ================================

# Token Discord (obligatoire)
TOKEN=ton_token_discord_ici

# ID de l'application Discord (obligatoire)
CLIENT_ID=ton_client_id_ici

# Préfixe de secours pour les commandes legacy (optionnel)
PREFIX=!

# ID du salon de logs global (optionnel)
LOG_CHANNEL_ID=

# Couleur principale du bot (hex)
COLOR=#7B2FBE

# Mode développement (true/false)
DEV_MODE=false

# ID du serveur de dev (si DEV_MODE=true)
DEV_GUILD_ID=

# API de blagues (optionnel — laisser vide pour les blagues intégrées)
BLAGUES_API_KEY=
